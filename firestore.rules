rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - uid: string (required) - Owner of the report
    //   - mode: string (required) - 'A' or 'B'
    //   - createdAt: timestamp (required)
    //   - stroke: string (optional)
    //   - findings: list (optional)
    //   - suggestions: list (optional)
    //   - metrics: map (optional)
    //   - trainingPlan: map (optional)
    //   - growthAdvice: string (required)
    //   - missingData: list (optional)
    //   - event: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "molson0411@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'updatedAt']) &&
             data.uid is string &&
             data.email is string &&
             data.updatedAt is timestamp;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['uid', 'mode', 'createdAt', 'growthAdvice']) &&
             data.uid is string &&
             data.mode in ['A', 'B'] &&
             data.createdAt is timestamp &&
             data.growthAdvice is string &&
             data.growthAdvice.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /reports/{reportId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid && 
                      isValidReport(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.uid == resource.data.uid &&
                      isValidReport(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
