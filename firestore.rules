rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - freeCredits: number (required, initialized to 5)
    //   - updatedAt: timestamp (required)
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - uid: string (required) - Owner of the report
    //   - mode: string (required) - 'A' or 'B'
    //   - createdAt: timestamp (required)
    //   - stroke: string (optional)
    //   - findings: list (optional)
    //   - suggestions: list (optional)
    //   - metrics: map (optional)
    //   - trainingPlan: map (optional)
    //   - growthAdvice: string (required)
    //   - missingData: list (optional)
    //   - event: string (optional)
    //
    // Collection: analysis_reports
    // Document ID: {reportId}
    // Fields:
    //   - createdAt: timestamp (required)
    //   - strokeType: string (required)
    //   - aiReport: map (required) - Raw AI report JSON
    //   - status: string (required) - 'active', 'deleted', or 'archived'
    //   - reviewStatus: string (required) - 'pending', 'approved', or 'revised'
    //   - adminFeedback: string or null (required)
    //   - videoUrl: string or null (required)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "molson0411@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'updatedAt', 'freeCredits']) &&
             data.uid is string &&
             data.email is string &&
             data.freeCredits is number &&
             data.freeCredits >= 0 &&
             data.updatedAt is timestamp;
    }

    function isValidUserCreate(userId) {
      return isOwner(userId) &&
             isValidUser(request.resource.data) &&
             request.resource.data.freeCredits == 5 &&
             !('role' in request.resource.data);
    }

    function isValidUserUpdate(userId) {
      return isOwner(userId) &&
             isValidUser(request.resource.data) &&
             request.resource.data.uid == resource.data.uid &&
             (
               request.resource.data.freeCredits == resource.data.freeCredits ||
               (!('freeCredits' in resource.data) && request.resource.data.freeCredits == 5)
             ) &&
             (
               !('role' in request.resource.data) ||
               request.resource.data.role == resource.data.role
             );
    }

    function isValidReport(data) {
      return data.keys().hasAll(['uid', 'mode', 'createdAt', 'growthAdvice']) &&
             data.uid is string &&
             data.mode in ['A', 'B'] &&
             data.createdAt is timestamp &&
             data.growthAdvice is string &&
             data.growthAdvice.size() < 5000;
    }

    function isValidAnalysisReport(data) {
      return data.keys().hasOnly(['createdAt', 'strokeType', 'aiReport', 'status', 'reviewStatus', 'adminFeedback', 'videoUrl', 'updatedAt']) &&
             data.keys().hasAll(['createdAt', 'strokeType', 'aiReport', 'status', 'reviewStatus', 'adminFeedback', 'videoUrl']) &&
             data.createdAt is timestamp &&
             data.strokeType is string &&
             data.aiReport is map &&
             data.status in ['active', 'deleted', 'archived'] &&
             data.reviewStatus in ['pending', 'approved', 'revised'] &&
             (data.adminFeedback == null || data.adminFeedback is string) &&
             (data.videoUrl == null || data.videoUrl is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidAnalysisReviewUpdate() {
      return isValidAnalysisReport(request.resource.data) &&
             request.resource.data.createdAt == resource.data.createdAt &&
             request.resource.data.strokeType == resource.data.strokeType &&
             request.resource.data.aiReport == resource.data.aiReport &&
             request.resource.data.videoUrl == resource.data.videoUrl &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'reviewStatus', 'adminFeedback', 'updatedAt']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isValidUserCreate(userId);
      allow update: if isValidUserUpdate(userId);
    }

    match /reports/{reportId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid && 
                      isValidReport(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.uid == resource.data.uid &&
                      isValidReport(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /analysis_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin() && isValidAnalysisReviewUpdate();
      allow delete: if false;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
