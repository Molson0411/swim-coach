# GEMINI_API_KEY: Required by the backend/API proxy for Gemini AI API calls.
# Never expose this value in frontend builds.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional backend model override.
# Leave blank to use the default stable video-capable model: gemini-2.5-flash.
# Use gemini-2.5-pro only when you need higher-accuracy analysis.
GEMINI_MODEL="gemini-2.5-flash"

# Optional for GitHub Pages/static frontend builds.
# Local dev API defaults to http://localhost:3001.
# For deployed builds, set this to your deployed API proxy origin, for example:
# VITE_API_BASE_URL="https://your-api.vercel.app"
VITE_API_BASE_URL="http://localhost:3001"

# Optional CORS allow-list for the API proxy.
ALLOWED_ORIGINS="http://localhost:3000,https://molson0411.github.io"

# ECPay All-in-One payment integration.
# Use ECPay production credentials only on the server/API environment.
ECPAY_MERCHANT_ID=""
ECPAY_HASH_KEY=""
ECPAY_HASH_IV=""
ECPAY_RETURN_URL="https://your-api.vercel.app/api/payment/webhook"
ECPAY_CLIENT_BACK_URL="https://molson0411.github.io/swim-coach/"
APP_BASE_URL="https://molson0411.github.io/swim-coach/"
